---
interface Props {
  locale: "ru" | "en";
}

const { locale } = Astro.props;

const labels = {
  ru: {
    ru: "RU",
    en: "EN",
    pdfLabel: "PDF",
    pdfTitle: "Скачать PDF-версию резюме",
  },
  en: {
    ru: "RU",
    en: "EN",
    pdfLabel: "PDF",
    pdfTitle: "Download CV as PDF",
  },
};

const translation = labels[locale];
const ruHref = "/cv";
const enHref = "/en/cv";
const pdfHref = locale === "ru" ? "/files/cv.ru.pdf" : "/files/cv.en.pdf";
---

<div class="cv-controls">
  <div class="cv-controls-group">
    <nav class="cv-locale-switcher" aria-label="CV language switcher">
      <a class="cv-control-pill" href={ruHref} aria-current={locale === "ru" ? "page" : undefined}>
        {translation.ru}
      </a>
      <a class="cv-control-pill" href={enHref} aria-current={locale === "en" ? "page" : undefined}>
        {translation.en}
      </a>
    </nav>

    <a
      href={pdfHref}
      download
      class="cv-print-button cv-control-pill"
      aria-label={translation.pdfTitle}
      title={translation.pdfTitle}
    >
      {translation.pdfLabel}
    </a>
  </div>
</div>
