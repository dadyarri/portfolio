---
interface CVHeaderData {
  name: string;
  title: string;
  photo?: string;
  summary?: string;
}

interface Props {
  data: CVHeaderData;
}

const { data } = Astro.props;
const { name, title, photo, summary } = data;
---

<div class="cv-header">
  <div class="cv-header-content">
    <div class="cv-header-info">
      <h1>{title}</h1>
      <h2>{name}</h2>
      {summary && <p>{summary}</p>}
    </div>
    {
      photo && (
        <div class="cv-header-photo">
          <img src={photo} alt={`${name}'s photo`} />
        </div>
      )
    }
  </div>
</div>
