---
interface CVHeaderData {
  name: string;
  title: string;
  photo?: string;
  summary?: string;
}

interface Props {
  data: CVHeaderData;
}

const { data } = Astro.props;
const { name, title, photo, summary } = data;
---

<div class="cv-hero">
  <div class="cv-hero-body cv-flow">
    <p class="cv-eyebrow">{title}</p>
    <h1 class="cv-hero-title">{name}</h1>
    {summary && <p class="cv-muted cv-hero-summary">{summary}</p>}
  </div>
  {
    photo && (
      <div class="cv-hero-photo">
        <img src={photo} alt={`${name}'s photo`} />
      </div>
    )
  }
</div>
