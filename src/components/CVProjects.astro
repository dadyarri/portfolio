---
import type { Project } from "@type/cv";

interface Props {
  items: Project[];
  locale: "en-US" | "ru-RU";
}

const { items, locale } = Astro.props;

const translations = {
  "en-US": {
    stack: "Stack",
    links: "Links",
  },
  "ru-RU": {
    stack: "Стек",
    links: "Ссылки",
  },
};

const translation = translations[locale] || translations["en-US"];
---

<div class="cv-projects">
  {
    items.map((item) => (
      <div class="cv-project-item">
        <div class="cv-project-content">
          <h3>{item.title}</h3>
          {item.description}
          {item.stack && (
            <p>
              <strong>{translation.stack}:</strong> {item.stack.join(", ")}
            </p>
          )}
          {item.links && (
            <p>
              <strong>{translation.links}:</strong>{" "}
              {item.links.map((link, index, array) => (
                <>
                  <a href={link} target="_blank" rel="noopener noreferrer">
                    {link}
                  </a>
                  {index < array.length - 1 && ", "}
                </>
              ))}
            </p>
          )}
        </div>
      </div>
    ))
  }
</div>
