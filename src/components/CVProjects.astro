---
import type { Project } from "@type/cv";

interface Props {
  items: Project[];
  locale: "en-US" | "ru-RU";
}

const { items, locale } = Astro.props;

const translations = {
  "en-US": {
    stack: "Stack",
    links: "Links",
    aiUsage: {
      none: "no AI",
      partial: "partial AI",
      full: "AI",
    },
  },
  "ru-RU": {
    stack: "Стек",
    links: "Ссылки",
    aiUsage: {
      none: "без ИИ",
      partial: "частично с ИИ",
      full: "ИИ",
    },
  },
};

const translation = translations[locale] || translations["en-US"];
---

<div class="cv-flow">
  {
    items.map((item) => (
      <article class="cv-card">
        <div class="cv-card-header">
          <div class="cv-project-heading">
            <h3 class="cv-card-title">{item.title}</h3>
            <span class:list={["cv-project-ai-label", { "cv-project-ai-label--no-ai": item.aiUsage === "none" }]}>
              {translation.aiUsage[item.aiUsage]}
            </span>
          </div>
        </div>
        <p class="cv-copy">{item.description}</p>
        {item.stack && (
          <p class="cv-copy">
            <span class="cv-label">{translation.stack}</span>
            {item.stack.join(", ")}
          </p>
        )}
        {item.links && (
          <div class="cv-detail">
            <p class="cv-label">{translation.links}</p>
            <div class="cv-links">
              {item.links.map((link) => (
                <a href={link} target="_blank" rel="noopener noreferrer">
                  {link}
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    ))
  }
</div>
