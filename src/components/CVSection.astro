---
interface Props {
  title: string;
  pageBreakBefore?: boolean;
  keepTogether?: boolean;
}

const { title, pageBreakBefore = false, keepTogether = false } = Astro.props;
---

<section
  class:list={["cv-section", { "cv-section-keep": keepTogether }]}
  style={`--cv-break-before: ${pageBreakBefore ? "page" : "auto"}; --cv-page-break-before: ${pageBreakBefore ? "always" : "auto"}`}
>
  <div class="cv-section-heading">
    <h2 class="cv-section-title">{title}</h2>
  </div>
  <div class="cv-flow">
    <slot />
  </div>
</section>
