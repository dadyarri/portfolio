        "description": [
          {
            "id": "upsert-oracle",
            "text": {
              "ru": "Модифицировал open-source-проект FlexLabs.Upsert, добавив поддержку Oracle и внедрил его в продукт",
              "en": "Modified the open-source project FlexLabs.Upsert, adding Oracle support and integrated it into the product"
            }
          },
          {
            "id": "linux-build-docs",
            "text": {
              "ru": "Переписал и актуализировал документацию по сборке пакетов под российские Linux-дистрибутивы (Astra, Alt, РЕД ОС), добившись стабильной сборки на всех поддерживаемых системах",
              "en": "Rewrote and updated documentation for package builds for Russian Linux distributions (Astra, Alt, Red OS), achieving stable builds across all supported systems"
            }
          },
          {
            "id": "sqlite-queue",
            "text": {
              "ru": "Разработал персистентную очередь на базе SQLite, заменив унаследованное файловое решение и повысив надёжность сервисной архитектуры",
              "en": "Developed a persistent queue based on SQLite, replacing a legacy file-based solution and improving the reliability of the service architecture"
            }
          },
          {
            "id": "dependency-migration",
            "text": {
              "ru": "Выполнил миграцию устаревших библиотек и сопутствующих компонентов, что улучшило производительность и стабильность продукта",
              "en": "Migrated outdated libraries and associated components, enhancing product performance and stability"
            }
          },
          {
            "id": "interservice-refactor",
            "text": {
              "ru": "Перепроектировал механизм межсервисного взаимодействия, повысив его скорость и масштабируемость",
              "en": "Refactored the inter-service communication mechanism, increasing its speed and scalability"
            }
          },
          {
            "id": "packaging-manifests",
            "text": {
              "ru": "Оптимизировал манифесты пакетирования (deb, rpm), сократив время сборки и развертывания",
              "en": "Optimized packaging manifests (deb, rpm), reducing build and deployment time"
            }
          },
          {
            "id": "build-cli",
            "text": {
              "ru": "Создал универсальный CLI-инструмент для автоматизации сборки и пакетирования под Windows и Linux (включая Astra, Alt, РЕД ОС), что значительно ускорило CI/CD и снизило количество ошибок при выпуске новых пакетов",
              "en": "Created a universal CLI tool for automating builds and packaging for Windows and Linux (including Astra, Alt, Red OS), significantly accelerating CI/CD and reducing errors during new package releases"
            }
          },
          {
            "id": "tui-wrapper",
            "text": {
              "ru": "Разработал TUI-обёртку для CLI-инструмента, сделав процесс сборки и пакетирования более удобным и прозрачным для разработчиков",
              "en": "Developed a TUI wrapper for the CLI tool, making the build and packaging process more user-friendly and transparent for developers"
            }
          },
          {
            "id": "technical-docs",
            "text": {
              "ru": "Подготовил техническую документацию по новым компонентам и внутренним инструментам, что упростило их внедрение и поддержку в команде",
