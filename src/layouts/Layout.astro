---
import BaseLayout from "@layouts/BaseLayout.astro";
import type { AlternateLink, StructuredData } from "@type/seo";

const {
	title = "dadyarri",
	description = "Личный блог dadyarri",
	lang = "ru",
	canonicalUrl,
	ogTitle,
	ogDescription,
	ogType,
	ogImage,
	ogImageAlt,
	robots,
	locale,
	siteName,
	twitterSite,
	bodyClass,
	contentClass,
	showHeader,
	pageTitle,
	includeCvStyles,
	alternateLinks,
	structuredData,
} = Astro.props;

---

<BaseLayout
	title={title}
	description={description}
	lang={lang}
	canonicalUrl={canonicalUrl}
	ogTitle={ogTitle}
	ogDescription={ogDescription}
	ogType={ogType}
	ogImage={ogImage}
	ogImageAlt={ogImageAlt}
	robots={robots}
	locale={locale}
	siteName={siteName}
	twitterSite={twitterSite}
	bodyClass={bodyClass}
	contentClass={contentClass}
	showHeader={showHeader}
	pageTitle={pageTitle}
	includeCvStyles={includeCvStyles}
	alternateLinks={alternateLinks as AlternateLink[] | undefined}
	structuredData={structuredData as StructuredData | undefined}
>
	<slot />
</BaseLayout>
