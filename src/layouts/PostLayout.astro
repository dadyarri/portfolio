---
import BaseLayout from "@layouts/BaseLayout.astro";
import Comments from "@components/Comments.astro";
import PageTitle from "@components/PageTitle.astro";
import PostInfo from "@components/PostInfo.astro";
import PostSeries from "@components/PostSeries.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { getTagLabel } from "@utils/content";
import { getPreviewText } from "@utils/data";
import { buildArticleStructuredData, getAbsoluteSiteUrl } from "@utils/seo";
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";

type Props = {
    post: CollectionEntry<"posts"> | CollectionEntry<"minis">;
    headings: MarkdownHeading[];
};

const { post, headings } = Astro.props;

const preview = getPreviewText(post.rendered?.html ?? "");
const url = getAbsoluteSiteUrl(`/${post.collection}/${post.id}`);
const imageUrl = getAbsoluteSiteUrl(`/content/${post.collection}/${post.id}/og-image.png`);
const renderedHtml = post.rendered?.html ?? "";
const needsCodeImagesScript =
    renderedHtml.includes("<pre") || renderedHtml.includes("<img");
const needsScrollSpyScript = headings.length > 0;
const tagLabels = (
    await Promise.all(post.data.tags.map((tag) => getTagLabel(tag.id)))
).filter((tag): tag is string => Boolean(tag));
const articleStructuredData = buildArticleStructuredData({
    title: post.data.title,
    description: preview,
    canonicalUrl: url,
    imageUrl,
    publishedAt: post.data.date.toISOString(),
    locale: "ru",
    tags: tagLabels,
});
---

<BaseLayout
    title={post.data.title}
    description={preview}
    canonicalUrl={url}
    ogType="article"
    ogImage={imageUrl}
    ogImageAlt={post.data.title}
    robots="index, follow"
    lang="ru"
    locale="ru_RU"
    twitterSite="@dadyarri"
    pageTitle={null}
    contentClass="post-layout"
    structuredData={articleStructuredData}
>
    <Fragment slot="head">
        <meta
            property="article:published_time"
            content={post.data.date.toISOString()}
        />
        <meta property="article:author" content="https://t.me/dadyarri" />
        <meta property="article:section" content="Tech" />
        {
            tagLabels.map((tag) => (
                <meta
                    property="article:tag"
                    content={tag}
                />
            ))
        }
        {
            needsCodeImagesScript && (
                <script src="/js/code-images.js" defer is:inline></script>
            )
        }
        {
            needsScrollSpyScript && (
                <script src="/js/scrollspy.js" defer is:inline></script>
            )
        }
    </Fragment>
    <div class="content">
        <PageTitle title={post.data.title} />
        <PostInfo post={post} />
        {
            post.data.series && (
                <PostSeries
                    series={post.data.series.id}
                    currentPost={post.id}
                />
            )
        }
        <slot />
        <a href=`/${post.collection}` class="pagination-button">
            <Icon name="carbon:chevron-left" width={20} />
            <span>Назад</span>
        </a>
        {!post.data.draft && <Comments lang="ru" />}
    </div>
    {
        headings.length > 0 && (
            <aside>
                <TableOfContents headings={headings} />
            </aside>
        )
    }
</BaseLayout>
