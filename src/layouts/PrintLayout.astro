---
import BaseLayout from "@layouts/BaseLayout.astro";
import type { AlternateLink, StructuredData } from "@type/seo";

const {
  title = "CV",
  description = title,
  lang = "ru",
  canonicalUrl,
  robots,
  locale,
  ogImageAlt,
  twitterSite,
  alternateLinks,
  structuredData,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  canonicalUrl={canonicalUrl}
  robots={robots}
  locale={locale}
  ogImageAlt={ogImageAlt}
  twitterSite={twitterSite}
  bodyClass="print-layout"
  contentClass="content print-content"
  showHeader={false}
  pageTitle={null}
  alternateLinks={alternateLinks as AlternateLink[] | undefined}
  structuredData={structuredData as StructuredData | undefined}
>
  <slot />
</BaseLayout>
