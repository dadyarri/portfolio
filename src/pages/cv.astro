---
import Layout from "@layouts/Layout.astro";
import CVDocument from "@components/CVDocument.astro";
import { localizeCv } from "@utils/cv.mjs";
import { type CVData } from "@type/cv";

const typedCv = localizeCv("ru") as CVData;
---

<Layout
  title="Резюме"
  description="Резюме Даниила Голубева, C#/.NET-разработчика."
  lang="ru"
>
  <CVDocument data={typedCv} locale="ru" showControls />
</Layout>
