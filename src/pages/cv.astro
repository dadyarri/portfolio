---
import Layout from "@layouts/Layout.astro";
import CVHeader from "@components/CVHeader.astro";
import CVSection from "@components/CVSection.astro";
import CVTimeline from "@components/CVTimeline.astro";
import CVSkills from "@components/CVSkills.astro";
import CVContact from "@components/CVContact.astro";
import { cv } from "@data/cv.json" with { type: "json" };
import CVProjects from "@components/CVProjects.astro";
import { type CVData } from "@type/cv";

const typedCv = cv as CVData;
const { personalInfo, workExperience, education, skills, contactInfo, projects } = typedCv;

---

<Layout title="Резюме">
  <CVHeader data={personalInfo} />

  <CVSection title="Опыт работы">
    <CVTimeline items={workExperience} locale={"ru-RU"} />
  </CVSection>

  <CVSection title="Образование" pageBreakBefore>
    <CVTimeline items={education} locale={"ru-RU"} />
  </CVSection>

  <CVSection title="Навыки">
    <CVSkills categories={skills} />
  </CVSection>

  <CVSection title="Контакты">
    <CVContact contacts={contactInfo} />
  </CVSection>

  <CVSection title="Проекты" pageBreakBefore>
    <CVProjects items={projects} locale={"ru-RU"} />
  </CVSection>
</Layout>
