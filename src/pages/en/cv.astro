---
import Layout from "@layouts/Layout.astro";
import CVDocument from "@components/CVDocument.astro";
import { localizeCv } from "@utils/cv.mjs";
import { type CVData } from "@type/cv";

const typedCv = localizeCv("en") as CVData;
---

<Layout
  title="CV"
  description="English CV of Daniil Golubev, C#/.NET developer."
  lang="en"
>
  <CVDocument data={typedCv} locale="en" showControls />
</Layout>
