---
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import PostCards from "@components/PostCards.astro";
import { getMinis, getPosts } from "@utils/content";
import type { CollectionEntry } from "astro:content";
import { home } from "@data/home.json";

const allPosts: (CollectionEntry<"posts"> | CollectionEntry<"minis">)[] = [
    ...(await getPosts()),
    ...(await getMinis())
].sort((a, b) => {
  const dateA = new Date(a.data.date!).valueOf();
  const dateB = new Date(b.data.date!).valueOf();

  return dateB - dateA;
}).slice(0, 7);
---

<Layout title="Обо мне">
    <section class="home-hero">
        <div class="hero-copy">
            <p class="hero-lead">
                <Icon name="fa6-regular:hand-peace" /> {home.hero.lead}
            </p>
            <p class="hero-note">{home.hero.note}</p>
        </div>
        <div class="stack-widget" aria-label="Технологии и интересы">
            {
                home.stackGroups.map((group) => (
                    <div class="stack-row">
                        <span class="stack-title">{group.title}</span>
                        <div class="stack-pills">
                            {
                                group.items.map((item) => (
                                    <span class="stack-pill">
                                        <Icon name={item.icon} />
                                        <span>{item.label}</span>
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <div class="posts-header">
        <h2>Последние посты</h2>
        <div class="posts-header-links">
            <a href="/posts">Все</a>
            <a href="/rss.xml" target="_blank"
                ><Icon name="carbon:rss" /> RSS feed</a
            >
        </div>
    </div>

    <div>
        <PostCards posts={allPosts} />
    </div>
</Layout>
