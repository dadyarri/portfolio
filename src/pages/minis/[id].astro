---
import type { GetStaticPaths } from "astro";
import ContentEntryPage from "@components/ContentEntryPage.astro";
import { buildContentEntryStaticPaths } from "@utils/content-routes";

export const getStaticPaths = (async () => {
    return buildContentEntryStaticPaths("minis");
}) satisfies GetStaticPaths;

const post = Astro.props;
---

<ContentEntryPage entry={post} />
