---
import ContentCollectionPage from "@components/ContentCollectionPage.astro";
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getMinis } from "@utils/content";
import { config } from "@data/config.json";
import { getContentTitle } from "@utils/content-routes";

export const getStaticPaths = (async ({ paginate }) => {
    return paginate(await getMinis(), { pageSize: config.pageSize });
}) satisfies GetStaticPaths;

const { page } = Astro.props as {
    page: {
        data: CollectionEntry<"minis">[];
        currentPage: number;
        lastPage: number;
    };
};
---

<ContentCollectionPage
  title={getContentTitle("minis")}
  category="minis"
  entries={page.data}
  currentPage={page.currentPage}
  pagesAmount={page.lastPage}
/>
