---
import type { GetStaticPaths } from "astro";
import { type CollectionEntry } from "astro:content";
import TaxonomyContentPage from "@components/TaxonomyContentPage.astro";
import {
  buildSeriesStaticPaths,
  getContentTitle,
  getSeriesContent,
} from "@utils/content-routes";

export const getStaticPaths = (async () => {
    return buildSeriesStaticPaths();
}) satisfies GetStaticPaths;

type Props = CollectionEntry<'series'>
const series = Astro.props
const seriesLabel = series.data.label;

const posts = await getSeriesContent("minis", series.id);
---

<TaxonomyContentPage
  title={`${getContentTitle("minis")} в цикле ${seriesLabel}`}
  entries={posts}
/>
