---
import ContentCollectionPage from "@components/ContentCollectionPage.astro";
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getPosts } from "@utils/content";
import { config } from "@data/config.json";
import { getContentTitle } from "@utils/content-routes";

export const getStaticPaths = (async ({ paginate }) => {
    return paginate(await getPosts(), { pageSize: config.pageSize });
}) satisfies GetStaticPaths;

const { page } = Astro.props as {
    page: {
        data: CollectionEntry<"posts">[];
        currentPage: number;
        lastPage: number;
    };
};
---

<ContentCollectionPage
  title={getContentTitle("posts")}
  category="posts"
  entries={page.data}
  currentPage={page.currentPage}
  pagesAmount={page.lastPage}
/>
