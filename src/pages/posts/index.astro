---
import ContentCollectionPage from "@components/ContentCollectionPage.astro";
import { getContentTitle, getFirstPageContent } from "@utils/content-routes";

const { pagesAmount, firstPageEntries } = await getFirstPageContent("posts");
---

<ContentCollectionPage
  title={getContentTitle("posts")}
  category="posts"
  entries={firstPageEntries}
  currentPage={1}
  pagesAmount={pagesAmount}
/>
