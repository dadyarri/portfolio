---
import type { GetStaticPaths } from "astro";
import { type CollectionEntry } from "astro:content";
import TaxonomyContentPage from "@components/TaxonomyContentPage.astro";
import {
  buildTagStaticPaths,
  getContentTitle,
  getTagContent,
} from "@utils/content-routes";

export const getStaticPaths = (async () => {
    return buildTagStaticPaths();
}) satisfies GetStaticPaths;

type Props = CollectionEntry<'tags'>
const tag = Astro.props

const posts = await getTagContent("posts", tag.id)

---

<TaxonomyContentPage
  title={`${getContentTitle("posts")} с тегом ${tag.data.label}`}
  entries={posts}
/>
